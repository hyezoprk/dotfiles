+/// After `/clear`, Claude creates a new JSONL with a fresh UUID while the session
+/// JSON ({PID}.json) still points to the old session-id. Find the newest unowned
+/// JSONL in `project_dir` that is newer than `matched_path` and not itself a live
+/// session-id — that file is the post-/clear conversation.
+fn find_post_clear_jsonl(
+    project_dir: &std::path::Path,
+    matched_path: &std::path::Path,
+    live_map: &HashMap<String, LiveSessionInfo>,
+) -> Option<PathBuf> {
+    let matched_mtime = matched_path.metadata().ok()?.modified().ok()?;
+    fs::read_dir(project_dir)
+        .ok()?
+        .flatten()
+        .filter_map(|e| {
+            let p = e.path();
+            if p.is_dir() {
+                return None;
+            }
+            if p.extension().map(|x| x != "jsonl").unwrap_or(true) {
+                return None;
+            }
+            let stem = p.file_stem()?.to_string_lossy().to_string();
+            if live_map.contains_key(&stem) {
+                return None;
+            }
+            let mtime = p.metadata().ok()?.modified().ok()?;
+            if mtime <= matched_mtime {
+                return None;
+            }
+            Some((mtime, p))
+        })
+        .max_by_key(|(mtime, _)| *mtime)
+        .map(|(_, p)| p)
+}
